{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting": "Information"
    }
  },
  "AllowedHosts": "*",
  "Certificate": {
    "ExpiringSoonDays": 15,
    "DefaultRenewalDaysBeforeExpiry": 15,
    "CertificateValidityDays": 90,
    "RenewalCheckIntervalHours": 6
  },
  "Auth": {
    "Issuer": "DockerPanel",
    "Audience": "DockerPanel.Web",
    "AccessTokenExpirationMinutes": 60,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "JwtSecretFile": "Data/jwt-secret.key"
  },
  "LiteDB": {
    "Path": "Data/DockerPanel.db"
  },
  "TinyDb": {
    "Path": "Data/DockerPanel.db"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://localhost:5174",
      "http://localhost:5175",
      "http://localhost:5179",
      "http://localhost"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/DockerPanel-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "ReverseProxy": {
    "Routes": {
      "acme-challenge-route": {
        "ClusterId": "acme-cluster",
        "Match": {
          "Path": "/.well-known/acme-challenge/{**path}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/acme/acme-challenge/{**path}"
          }
        ]
      },
      "acme-challenge-direct-route": {
        "ClusterId": "acme-cluster",
        "Match": {
          "Path": "/acme-challenge/{**path}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/acme/acme-challenge/{**path}"
          }
        ]
      }
    },
    "Clusters": {
      "acme-cluster": {
        "Destinations": {
          "local-api": {
            "Address": "http://localhost:80"
          }
        }
      }
    }
  }
}
